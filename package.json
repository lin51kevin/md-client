{
  "name": "marklite",
  "private": true,
  "version": "0.10.6",
  "description": "A lightweight Markdown & code editor built with Tauri, React, and CodeMirror",
  "author": "kevin",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/lin51kevin/md-client.git"
  },
  "homepage": "https://github.com/lin51kevin/md-client",
  "bugs": {
    "url": "https://github.com/lin51kevin/md-client/issues"
  },
  "keywords": [
    "markdown",
    "editor",
    "tauri",
    "react",
    "codemirror",
    "desktop"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "resolutions": {
    "html-encoding-sniffer": "4.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "node -e \"require('fs').rmSync('public/plugins',{recursive:true,force:true})\" && node scripts/build-plugins.mjs --resources-only && tsc && vite build",
    "analyze": "tsc && cross-env ANALYZE=true vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "changelog": "git-chglog -o CHANGELOG.md",
    "changelog:latest": "git-chglog $(git describe --tags --abbrev=0)..",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:zip": "node scripts/create-zip.js",
    "build:plugins": "node scripts/build-plugins.mjs",
    "build:nsis": "makensis deploy/installer.nsi",
    "build:dist": "yarn tauri build && yarn build:zip",
    "test:e2e": "cd e2e-tests && yarn test"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@milkdown/crepe": "^7.20.0",
    "@milkdown/kit": "^7.20.0",
    "@milkdown/preset-gfm": "^7.20.0",
    "@milkdown/react": "^7.20.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "~2",
    "@tauri-apps/plugin-fs": "~2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@uiw/react-codemirror": "^4.25.7",
    "codemirror": "^6.0.2",
    "dompurify": "^3.2.4",
    "epub-gen-memory": "^1.1.2",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "js-yaml": "^4.1.0",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-split": "^2.0.14",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-directive-rehype": "^1.0.0",
    "remark-footnotes": "^4.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "turndown": "^7.2.4",
    "unist-util-visit": "^5.1.0",
    "zustand": "^5.0.12",
    "@codemirror/indent-guides": "^1.0.0",
    "@codemirror/minimap": "^0.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.2.0",
    "@types/html2canvas": "^1.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "@replit/codemirror-vim": "^6.3.0",
    "katex": "^0.16.45",
    "mermaid": "^11.14.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "happy-dom": "^15.0.0",
    "jsdom": "^29.0.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "symbol-tree": "^3.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.0",
    "vitest": "3.2.3"
  }
}
