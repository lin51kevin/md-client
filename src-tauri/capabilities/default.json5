{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    // Core defaults and window management
    "core:default",
    "core:window:allow-show",
    "core:window:allow-maximize",
    "core:window:allow-set-title",
    "core:window:allow-set-theme",

    // Open links in default browser
    "opener:default",

    // Native file dialogs (open/save)
    "dialog:default",

    // File system defaults (metadata, stat, etc.)
    "fs:default",

    // Read text files - needed: user can open .md from any location
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "**" }] // Markdown editor must open files from arbitrary paths
    },
    // Read bundled resources (e.g. plugins directory)
    "fs:allow-resource-read-recursive",

    // Write files - needed: user can save .md to any location
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "**" }] // Markdown editor must save files to arbitrary paths
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "**" }] // Markdown editor must save text files to arbitrary paths
    },

    // File watching - needed: auto-reload when external editor modifies the file
    {
      "identifier": "fs:allow-watch",
      "allow": [{ "path": "**" }] // Watch opened files for external changes
    },
    {
      "identifier": "fs:allow-unwatch",
      "allow": [{ "path": "**" }] // Unwatch when file is closed
    },

    // Auto-update from GitHub releases
    "updater:default"
  ]
}
