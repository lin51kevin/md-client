<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="CleanupStaleUninstallShortcut" Guid="*">
        <RemoveFile Id="RemoveOldUninstallShortcutName" Name="Uninstall MarkLite++.lnk" On="both" />
        <RemoveFile Id="RemoveOldUninstallShortcutPattern" Name="Uninstall*.lnk" On="both" />
        <RegistryValue
          Root="HKCU"
          Key="Software\lin51kevin\MarkLite++"
          Name="Cleanup Stale Uninstall Shortcut"
          Type="integer"
          Value="1"
          KeyPath="yes"
        />
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
