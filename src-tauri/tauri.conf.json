{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkLite",
  "version": "0.9.0",
  "identifier": "com.lin51kevin.marklite",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MarkLite",
        "width": 1280,
        "height": 800,
        "visible": false,
        "backgroundColor": "#0d1117"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http://localhost:*; style-src 'self' 'unsafe-inline'; img-src 'self' data:;"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/lin51kevin/md-client/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd", "mdx"],
        "name": "Markdown Document",
        "description": "Markdown Document",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ]
  }
}
